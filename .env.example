DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ALLOWED_ORIGIN=
PORT=
# Customer auto-emails: "true" attempts real delivery, anything else = dry-run
# (compose + log only). Sweep cadence in ms (default 120000 = 2 min).
EMAIL_ENABLED=
EMAIL_SWEEP_INTERVAL_MS=
# No-reply sender identity (one-way notifications; no Reply-To is set). The
# address must be on a domain verified with the provider.
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=
# Resend API key (https://resend.com) — required when EMAIL_ENABLED=true.
RESEND_API_KEY=
