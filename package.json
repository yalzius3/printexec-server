{
  "name": "@xyz/server",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "start:prod": "node dist/src/main.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "db:inspect": "node --env-file=.env scripts/inspect-schema.mjs",
    "db:run-file": "node --env-file=.env scripts/run-sql-file.mjs",
    "db:seed-refs": "node --env-file=.env scripts/seed-reference-catalog.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-fastify": "^11.1.8",
    "@supabase/supabase-js": "^2.105.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@xyz/shared": "file:./shared",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.16.0",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@types/node": "^24.7.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
